# Copy this file to .env and fill in your values.
# The backend uses this to call the Anthropic API for entity extraction.
ANTHROPIC_API_KEY=sk-ant-...

# Free-tier fallback (no credit card needed).
# Get a key at: https://aistudio.google.com/app/apikey
# Limits: 15 RPM, 1M tokens/day, 1M token context (no chunking needed).
GEMINI_API_KEY=

# Frontend API base URL (leave empty for same-origin / Docker; set for custom deployments)
# VITE_API_BASE_URL=http://localhost:8000

# Optional overrides (defaults shown)
# DATABASE_URL=sqlite:///./founder_brain_audit.db
# UPLOAD_DIR=./uploads
# MAX_UPLOAD_SIZE_MB=50
# EXTRACTION_MODEL=claude-haiku-4-5-20251001
# SIMILARITY_THRESHOLD=0.80
